# Local-only LiveKit dev defaults — override LIVEKIT_URL to point at LiveKit Cloud.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# To reach this app from another device on the LAN (e.g. a tablet over
# Wi-Fi), set both to this machine's LAN IP — the container can't route
# back to the host's own LAN address (hairpin NAT), so the agent keeps
# using LIVEKIT_URL above while browsers get LIVEKIT_PUBLIC_URL instead.
# LIVEKIT_PUBLIC_URL=ws://<this-machine-LAN-IP>:7880
# LIVEKIT_NODE_IP=<this-machine-LAN-IP>

# LLM (llama.cpp server is a managed subprocess by default)
LLAMA_BASE_URL=http://127.0.0.1:11434/v1
LLAMA_MODEL=gemma-4-e2b
LLAMA_MODEL_ALIAS=gemma-4-e2b
LLAMA_HF_REPO=unsloth/gemma-4-E2B-it-qat-GGUF:UD-Q4_K_XL
# Offline use: once the model is cached, it starts with no internet
# automatically. Force it with LLAMA_OFFLINE=1 (or LLAMA_OFFLINE=0 to always
# re-check Hugging Face), or set LLAMA_MODEL_PATH to load a local .gguf directly.
# LLAMA_OFFLINE=1
# LLAMA_MODEL_PATH=/models/gemma-4-E2B-it-qat-UD-Q4_K_XL.gguf
LLAMA_CTX_SIZE=16384
# LLAMA_N_GPU_LAYERS: CPU default is 0; the GPU overlay defaults to 999 (full
# offload). Set it here only to force a specific value in both modes.

# STT (Nemotron is the default; set STT_PROVIDER=whisper for the vox-box fallback)
STT_PROVIDER=nemotron
STT_BASE_URL=http://127.0.0.1:8000/v1
STT_MODEL=nemotron-speech-streaming
STT_API_KEY=no-key-needed
NEMOTRON_MODEL_NAME=nvidia/nemotron-speech-streaming-en-0.6b
NEMOTRON_MODEL_ID=nemotron-speech-streaming

# TTS (Kokoro)
TTS_BASE_URL=http://127.0.0.1:8880/v1
# af_heart is Kokoro's top-graded voice — warm and well-suited for narrating
# stories to a young child.
TTS_VOICE=af_heart

# Telugu/Marathi TTS (Meta MMS) — off by default, extra model downloads.
ENABLE_INDIC_TTS=1

# Web (FastAPI: token route + static frontend)
WEB_PORT=8091

# Optional Whisper fallback (STT_PROVIDER=whisper)
WHISPER_MODEL=Systran/faster-whisper-small

# Wake word: set WAKE_WORD=1 to make the agent listen only after "hey livekit".
# Detection scores are logged (log level DEBUG) — tune WAKE_WORD_THRESHOLD to
# your microphone if needed.
# WAKE_WORD=1
# WAKE_WORD_THRESHOLD=0.5
